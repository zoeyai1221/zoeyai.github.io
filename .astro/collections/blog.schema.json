{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "pubDate": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "format": "date-time"
        }
      ]
    },
    "customData": {
      "type": "string"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "author": {
      "type": "string"
    },
    "commentsUrl": {
      "type": "string"
    },
    "source": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "url",
        "title"
      ]
    },
    "enclosure": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string"
        },
        "length": {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        "type": {
          "type": "string"
        }
      },
      "required": [
        "url",
        "length",
        "type"
      ]
    },
    "link": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  }
}