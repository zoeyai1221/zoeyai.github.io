---
import { Icon } from "astro-icon/components";

type Entry = {
  id: string;
  type: "work" | "education";
  title: string;
  subtitle: string;
  startYear: number;
  startMonth: number;
  endYear: number;
  endMonth: number;
  location: string;
  bullets: string[];
};

const MN = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];

const LATEST      = 2026 * 12 + 4; // Apr 2026 — top of timeline
const SLOT_OFFSET = 40;            // first work slot top (clears NEU icon)
const SLOT_H      = 160;           // fixed px between work card tops
const PPM_EDU     = 7;             // px/month — edu box placement only
const MAX_EDU_H   = 160;           // cap edu duration area height

const durMo = (e: Entry) => e.endYear * 12 + e.endMonth - e.startYear * 12 - e.startMonth;
const fmtP  = (e: Entry) => `${MN[e.startMonth-1]} ${e.startYear} – ${MN[e.endMonth-1]} ${e.endYear}`;
const fmtD  = (m: number) => {
  const y = Math.floor(m/12), mo = m%12;
  if (!y) return `${mo} mo${mo!==1?"s":""}`;
  if (!mo) return `${y} yr${y!==1?"s":""}`;
  return `${y} yr${y!==1?"s":""} ${mo} mo${mo!==1?"s":""}`;
};

const entries: Entry[] = [
  {
    id:"slicpix", type:"work",
    title:"SlicPix, Inc.", subtitle:"Software Engineer Co-op",
    startYear:2025, startMonth:9, endYear:2026, endMonth:2,
    location:"Seattle, WA",
    bullets:[
      "Led UAT process for AI-powered features across Shopify app extension and Interactive Studio 2.0, validating backend-frontend interactions against business requirements.",
      "Partnered with founding team on product scoping and release readiness, aligning cross-functional requirements with go-to-market timelines.",
      "Supported GTM strategy and investor pitch framing, translating technical capabilities into business value narratives.",
    ],
  },
  {
    id:"neu", type:"education",
    title:"Northeastern University", subtitle:"MS Computer Science · GPA 4.0",
    startYear:2023, startMonth:9, endYear:2026, endMonth:4,
    location:"Seattle, WA",
    bullets:[
      "GPA: 4.0 / 4.0, expected graduation April 2026.",
      "Relevant coursework: Algorithms, Database Systems, Software Engineering, Machine Learning.",
    ],
  },
  {
    id:"aws", type:"work",
    title:"Amazon Web Services", subtitle:"Business Operations Manager",
    startYear:2022, startMonth:2, endYear:2023, endMonth:8,
    location:"Shanghai, China",
    bullets:[
      "Orchestrated strategic alignment between GCR C-suite and 20+ teams for a $3.5B+ revenue business.",
      "Defined requirements and led delivery of an Anaplan-based forecasting tool, improving efficiency for 1,000+ sales reps.",
      "Built SQL and Tableau pipelines processing 600K+ monthly records, reducing manual reporting by 90%.",
      "Delivered weekly competitive benchmarking analyses to GCR C-suite and 6 sales BUs.",
    ],
  },
  {
    id:"amazon", type:"work",
    title:"Amazon.com, Inc.", subtitle:"Financial Analyst, Logistics",
    startYear:2020, startMonth:5, endYear:2022, endMonth:2,
    location:"Seattle, WA",
    bullets:[
      "Built a centralized tracking system across 300+ logistics stations, closing a critical data visibility gap.",
      "Developed Python and SQL forecasting models, improving forecast accuracy by 30%.",
      "Led financial decision-making for 300+ station launches aligned with $400M+ CAPEX strategy.",
      "Championed ERP and BI tool adoption; standardized workflows across 300+ stations.",
    ],
  },
  {
    id:"huawei", type:"work",
    title:"Huawei Technologies, Inc.", subtitle:"Financial Planning Analyst",
    startYear:2018, startMonth:9, endYear:2020, endMonth:2,
    location:"Plano, TX",
    bullets:[
      "Administered Workday ERP rollout for 50+ Finance and executive users, improving efficiency by 50%.",
      "Consolidated 500K+ monthly expense records from 30+ enterprise systems for executive reporting.",
      "Managed forecasting for 40+ R&D projects ($60M+ budget), achieving 94% spend execution.",
    ],
  },
  {
    id:"utd", type:"education",
    title:"Univ. of Texas at Dallas", subtitle:"MS Finance & Business Analytics · GPA 3.65",
    startYear:2016, startMonth:8, endYear:2019, endMonth:5,
    location:"Dallas, TX",
    bullets:[
      "GPA: 3.65 / 4.0.",
      "Honors: Dean's Excellent Scholarship, Dean's Impact Scholarship.",
      "Certified Excellent Graduate Student.",
    ],
  },
];

// Work: fixed slots (newest first), no proportional scaling → no overlap
const workEntries = entries
  .filter(e => e.type === "work")
  .sort((a, b) => (b.startYear * 12 + b.startMonth) - (a.startYear * 12 + a.startMonth))
  .map((e, i) => ({
    ...e,
    slotTop:  SLOT_OFFSET + i * SLOT_H,
    period:   fmtP(e),
    durLabel: fmtD(durMo(e)),
  }));

const EDU_CARD_H = 108; // p-4 padding + text lines in edu card

// Education: proportional placement, per-entry sizing and width
const eduEntries = entries
  .filter(e => e.type === "education")
  .map(e => {
    // NEU card min-height extends to SlicPix's bottom so it visually "contains" it
    // SlicPix bottom = SLOT_OFFSET + header(36) + card(EDU_CARD_H)
    // NEU card starts after its own header (36px), so min-height = SlicPix bottom - 36
    const cardMinH = e.id === "neu" ? SLOT_OFFSET + EDU_CARD_H + 20 : 0;
    return {
      ...e,
      endTop:   (LATEST - (e.endYear * 12 + e.endMonth)) * PPM_EDU,
      cardMinH,
      boxRight: "0px",
      period:   fmtP(e),
      durLabel: fmtD(durMo(e)),
    };
  });

// Mobile: all entries sorted newest-first
const allEntries = [...workEntries, ...eduEntries]
  .sort((a, b) => (b.startYear * 12 + b.startMonth) - (a.startYear * 12 + a.startMonth));

const CONTAINER_H = Math.max(
  SLOT_OFFSET + workEntries.length * SLOT_H + 80,
  ...eduEntries.map(e => e.endTop + e.cardMinH + 300),
);
---

<section class="w-full max-w-6xl mx-auto px-4 sm:px-6 py-10 pb-24">
  <div class="flex items-center gap-4 mb-10">
    <h2 class="text-2xl font-bold whitespace-nowrap"
        style="font-family:var(--font-cabinet-grotesk)">
      Experience & Education
    </h2>
    <div class="flex-1 h-px bg-black/20"></div>
  </div>

  <!-- ═══ DESKTOP ═══ -->
  <div class="hidden md:block relative" style={`height:${CONTAINER_H}px`}>

    <!-- Center backbone -->
    <div class="absolute left-1/2 top-0 bottom-0 w-px -translate-x-1/2 bg-black/12 z-0"></div>

    <!-- ── Education boxes (RIGHT side, span full duration) ── -->
    <!--
      Each edu box:
        top    = endTop  (the END date, near top of timeline)
        height = durPx + card content area
        The box visually "owns" the whole period.
        Work cards on the LEFT that fall within this vertical range
        appear to be "inside" the edu period — showing concurrency.
    -->
    {eduEntries.map(e => (
      <div
        class="absolute z-2"
        style={`top:${e.endTop}px; left:calc(50% + 16px); right:${e.boxRight};`}
      >
        <!-- Date label + icon outside the card, above it (mirrors work card layout) -->
        <div class="relative flex items-center mb-2">
          <div class="absolute left-[-30px] z-20">
            <div class="w-7 h-7 rounded-md border-2 border-black bg-[#bae6ff] flex items-center justify-center shadow-[2px_2px_0px_rgba(0,0,0,0.12)]">
              <Icon name="ri:graduation-cap-line" class="w-3.5 h-3.5" />
            </div>
          </div>
          <span class="text-[11px] text-darkslate-300 italic whitespace-nowrap">
            {e.period}&ensp;
            <span class="not-italic font-medium text-black/45">({e.durLabel})</span>
          </span>
        </div>
        <!-- Card content from top, same structure as work cards -->
        <div class="border border-black rounded-lg bg-white p-4 shadow-[4px_4px_0px_rgba(0,0,0,0.10)] hover:border-[#7ecfff] transition-colors cursor-pointer"
             data-open-modal={`modal-${e.id}`}
             style={e.cardMinH ? `min-height:${e.cardMinH}px` : ""}>
          <h3 class="font-bold text-sm leading-snug">{e.title}</h3>
          <p class="text-xs font-semibold mt-0.5 text-blue-500">{e.subtitle}</p>
          <p class="text-xs text-darkslate-300 mt-0.5">{e.location}</p>
          <button
            data-open-modal={`modal-${e.id}`}
            class="mt-3 text-xs font-semibold hover:underline underline-offset-2 cursor-pointer"
          >
            Read more →
          </button>
        </div>
      </div>
    ))}

    <!-- ── Work cards (LEFT side, anchored at start date) ── -->
    {workEntries.map(e => (
      <div
        class="absolute left-0 right-0 z-10 pointer-events-none"
        style={`top:${e.slotTop}px`}
      >
        <!-- Date label + icon row -->
        <div class="relative flex items-center mb-2">
          <div class="w-1/2 flex justify-end pr-5">
            <span class="text-[11px] text-darkslate-300 italic">
              {e.period}&ensp;
              <span class="not-italic font-medium text-black/45">({e.durLabel})</span>
            </span>
          </div>
          <!-- Icon on center line -->
          <div class="absolute left-1/2 -translate-x-1/2 z-20">
            <div class="w-7 h-7 rounded-md border-2 border-black bg-primary-500 flex items-center justify-center shadow-[2px_2px_0px_rgba(0,0,0,0.12)]">
              <Icon name="ri:briefcase-2-line" class="w-3.5 h-3.5" />
            </div>
          </div>
          <div class="w-1/2 pl-5"></div>
        </div>

        <!-- Card on left half -->
        <div class="w-1/2 pr-5 pointer-events-auto">
          <div class="border border-black rounded-lg bg-white p-4 shadow-[4px_4px_0px_rgba(0,0,0,0.10)] hover:border-primary-500 transition-colors cursor-pointer" data-open-modal={`modal-${e.id}`}>
            <h3 class="font-bold text-sm leading-snug">{e.title}</h3>
            <p class="text-xs font-semibold mt-0.5 text-amber-600">{e.subtitle}</p>
            <p class="text-xs text-darkslate-300 mt-0.5">{e.location}</p>
            <button
              data-open-modal={`modal-${e.id}`}
              class="mt-3 text-xs font-semibold hover:underline underline-offset-2 cursor-pointer"
            >
              Read more →
            </button>
          </div>
        </div>
      </div>
    ))}

  </div><!-- /desktop -->

  <!-- ═══ MOBILE: flat list ═══ -->
  <div class="md:hidden space-y-3">
    {allEntries.map(e => (
      <div class={`relative border rounded-lg bg-white p-4 shadow-[4px_4px_0px_rgba(0,0,0,0.10)] pl-8 ${e.type==="work" ? "border-black" : "border-dashed border-[#7ecfff]"}`}>
        <div class={`absolute left-3 top-5 w-[10px] h-[10px] rounded-full border-2 border-black ${e.type==="work" ? "bg-primary-500" : "bg-[#bae6ff]"}`} />
        <div class="flex flex-wrap items-start justify-between gap-1 mb-0.5">
          <h3 class="font-bold text-sm">{e.title}</h3>
          <span class={`text-[10px] font-semibold px-2 py-0.5 border border-black rounded-full ${e.type==="work" ? "bg-primary-500" : "bg-[#bae6ff]"}`}>
            {e.period}
          </span>
        </div>
        <p class={`text-xs font-semibold ${e.type==="work" ? "text-amber-600" : "text-blue-500"}`}>{e.subtitle}</p>
        <p class="text-xs text-darkslate-300 mt-0.5">{e.location}</p>
        <button
          data-open-modal={`modal-${e.id}`}
          class="mt-2.5 text-xs font-semibold hover:underline underline-offset-2 cursor-pointer"
        >
          Read more →
        </button>
      </div>
    ))}
  </div>
</section>

<!-- ═══ Modals ═══ -->
{entries.map(e => (
  <dialog id={`modal-${e.id}`} class="timeline-dialog">
    <div class="bg-white border border-black rounded-lg shadow-[8px_8px_0px_rgba(0,0,0,0.12)] p-6 w-full">
      <div class="flex justify-between items-start mb-5">
        <div>
          <div class="flex items-center gap-2 mb-1">
            <div class={`w-6 h-6 rounded border border-black flex items-center justify-center flex-shrink-0 ${e.type==="work" ? "bg-primary-500" : "bg-[#bae6ff]"}`}>
              <Icon name={e.type==="work" ? "ri:briefcase-2-line" : "ri:graduation-cap-line"} class="w-3.5 h-3.5" />
            </div>
            <h3 class="font-bold text-base">{e.title}</h3>
          </div>
          <p class={`text-sm font-semibold ${e.type==="work" ? "text-amber-600" : "text-blue-500"}`}>{e.subtitle}</p>
          <p class="text-xs text-darkslate-300 mt-1">{fmtP(e)}&ensp;·&ensp;{fmtD(durMo(e))}&ensp;·&ensp;{e.location}</p>
        </div>
        <button data-close-modal aria-label="Close"
                class="ml-4 text-xl leading-none text-darkslate-300 hover:text-black cursor-pointer flex-shrink-0">✕</button>
      </div>
      <ul class="space-y-2.5">
        {e.bullets.map(b => (
          <li class="flex gap-2.5 items-start text-sm">
            <span class="mt-[7px] w-1.5 h-1.5 rounded-full bg-black/35 flex-shrink-0" />
            <span class="leading-relaxed">{b}</span>
          </li>
        ))}
      </ul>
    </div>
  </dialog>
))}

<style is:global>
  .timeline-dialog {
    position: fixed; inset: 0; margin: auto;
    border: none; padding: 0; background: transparent;
    width: calc(100% - 2rem); max-width: 34rem;
    max-height: calc(100dvh - 4rem); overflow-y: auto;
  }
  .timeline-dialog::backdrop { background: rgba(0,0,0,0.45); }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll("[data-open-modal]").forEach(btn => {
      btn.addEventListener("click", () => {
        const id = (btn as HTMLElement).dataset.openModal;
        if (id) (document.getElementById(id) as HTMLDialogElement)?.showModal();
      });
    });
    document.querySelectorAll("[data-close-modal]").forEach(btn => {
      btn.addEventListener("click", () => {
        (btn as HTMLElement).closest("dialog")?.close();
      });
    });
    document.querySelectorAll("dialog.timeline-dialog").forEach(d => {
      d.addEventListener("click", e => {
        if (e.target === d) (d as HTMLDialogElement).close();
      });
    });
  });
</script>
